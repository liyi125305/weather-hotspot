# ============================================
# 气象今日热点 - 环境变量配置
# 复制本文件为 .env，然后填写真实值
# ============================================

# 和风天气 API Key
# 1. 访问 https://console.qweather.com/ 登录控制台
# 2. 进入「我的应用」→ 选择应用 → 复制 API Key
QWEATHER_API_KEY=

# 和风天气 API Host（可选，留空则用默认 devapi.qweather.com）
# 1. 在「我的应用」页面可以看到专属 API Host
# 2. 形如：xxxxxx.re.qweatherapi.com
QWEATHER_API_HOST=jy36x7cf38.re.qweatherapi.com

# 后端服务端口（默认 3001）
PORT=3001
